nconst vec3 SG_HAZE_LIGHT = vec3(0.910, 0.741, 0.769); /* #E8BDC4 */\nconst vec3 SG_WARM = vec3(0.541, 0.235, 0.196);\nconst vec3 SG_FIRE = vec3(1.000, 0.361, 0.000);\nconst vec3 SG_CORE = vec3(1.000, 0.894, 0.714);\n\n/* SuperGrok Heavy colours (blue flame – brighter / closer to white) */\nconst vec3 SH_HAZE = vec3(0.350, 0.450, 0.560); /* #59738F */\nconst vec3 SH_WARM = vec3(0.435, 0.639, 0.882); /* #6FA3E1 */\nconst vec3 SH_FIRE = vec3(0.435, 0.639, 0.882); /* #6FA3E1 */\nconst vec3 SH_CORE = vec3(0.720, 0.840, 1.000); /* #B8D6FF */\n\n/* ---- cheap hash (for hex tile shimmer) ----------------------- */\nfloat hash21(vec2 p) {\n  p = fract(p * vec2(123.34, 456.21));\n  p += dot(p, p + 45.32);\n  return fract(p.x * p.y);\n}\n\n/* ---- value noise (smooth, organic) --------------------------- */\nfloat vnoise(vec2 p) {\n  vec2 i = floor(p);\n  vec2 f = fract(p);\n  f = f * f * (3.0 - 2.0 * f);          /* smoothstep interp */\n  float a = hash21(i);\n  float b = hash21(i + vec2(1.0, 0.0));\n  float c = hash21(i + vec2(0.0, 1.0));\n  float d = hash21(i + vec2(1.0, 1.0));\n  return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);\n}\n\n/* Two octaves of value noise — organic without being expensive. */\nfloat fbm2(vec2 p) {\n  float v  = vnoise(p)        * 0.65;\n  v       += vnoise(p * 2.13) * 0.35;\n  return v;\n}\n\n/* ---- hexagonal tiling (pointy-top honeycomb) ----------------- */\n/*\n * Hex distance: 0 at center, 0.5 at edge.\n * Uses the standard pointy-top formula.\n */\nfloat hexDist(vec2 p) {\n  p = abs(p);\n  return max(dot(p, vec2(0.5, 0.866025)), p.x);\n}\n\n/*\n * Returns: xy = cell id,  z = edge distance (0 = edge).\n * Produces a proper pointy-top honeycomb grid.\n */\nvec3 hexTile(vec2 p, float scale) {\n  p *= scale;\n  vec2 r = vec2(1.0, 1.732051);\n  vec2 h = r * 0.5;\n  vec2 a = mod(p, r) - h;\n  vec2 b = mod(p - h, r) - h;\n  vec2 gv = (dot(a, a) < dot(b, b)) ? a : b;\n  float edgeDist = 0.5 - hexDist(gv);\n  vec2 id = p - gv;\n  return vec3(id / scale, edgeDist);\n}\n\n/* ---- oval glow (super-Gaussian) ------------------------------ */\nfloat ovalGlow(\n  vec2 uv, vec2 c, float hw, float hh, float sharp\n) {\n  float dx = (uv.x - c.x) / max(hw, 0.001);\n  float dy = (uv.y - c.y) / max(hh, 0.001);\n  float d2 = dx * dx + dy * dy;\n  return exp(-d2 * d2 * sharp);\n}\n\n/* ---- main ---------------------------------------------------- */\nvoid main() {\n  vec2 uv = vUv;\n  float aspect = u_resolution.x / u_resolution.y;\n  float h = max(u_plumeHeight, 0.001);\n  vec2 ctr = vec2(0.5, -0.06);\n\n  /* Pick colour palette based on subscription tier + theme */\n  vec3 SG_HAZE = u_isDark ? SG_HAZE_DARK : SG_HAZE_LIGHT;\n  vec3 COL_HAZE = u_isHeavy ? SH_HAZE : SG_HAZE;\n  vec3 COL_WARM = u_isHeavy ? SH_WARM : (u_isDark ? SG_WARM : SG_HAZE_LIGHT);\n  vec3 COL_FIRE = u_isHeavy ? SH_FIRE : SG_FIRE;\n  vec3 COL_CORE = u_isHeavy ? SH_CORE : SG_CORE;\n\n  /* ---- 1. Four-oval plume ------------------------------------ */\n  /*\n   * Tighter ovals so they read as distinct layers,\n   * not one big blob.  Heights scale with h for the\n   * grow/shrink lifecycle.\n   *\n   *          half-w   half-h   sharp\n   * haze:    wide     tall     soft    → atmospheric wash\n   * warm:    medium   medium   medium  → red-brown band\n   * fire:    wide     short    medium  → bright orange bar\n   * core:    medium   thin     tight   → hot white-gold line\n   */\n  /* Width driven by u_plumeWidth uniform — decoupled\n     from height so the scene can widen during winddown\n     independently of the height fading out. */\n  float wSpread = max(u_plumeWidth, 0.001);\n\n  /* Rounded dome plume — wider ovals with softer\n     falloff for a gradual, atmospheric look.\n     Haze sits higher so the dark envelope extends\n     above the bright flame (matching Figma). */\n  float o1 = ovalGlow(uv, ctr + vec2(0.0, 0.12),  0.48 * wSpread, 0.92 * h, 1.0);\n  float o2 = ovalGlow(uv, ctr + vec2(0.0, 0.01),  0.30 * wSpread, 0.40 * h, 1.4);\n  float o3 = ovalGlow(uv, ctr + vec2(0.0, 0.02),  0.20 * wSpread, 0.22 * h, 1.8);\n  float o4 = ovalGlow(uv, ctr + vec2(0.0, 0.02),  0.10 * wSpread, 0.10 * h, 2.5);\n\n  /* Heat field for tile warmth — o1 drives wider glow reach */\n  float heat = (o1 * 0.4 + o2 * 0.5 + o3 + o4)\n             * u_intensity;\n  heat = min(heat, 1.0);\n\n  /* ---- 2. Hex heat-shield tiles ------------------------------ */\n  vec2 hexUv = vec2(uv.x * aspect, uv.y);\n  vec3 hex = hexTile(hexUv, 45.0);\n  float edgeLine = 1.0 - smoothstep(0.0, 0.025, hex.z);\n  /* Tiles fade in from bottom → top: invisible at the\n     flame core, fully visible further up. */\n  edgeLine *= smoothstep(0.0, 0.25, uv.y);\n\n  /* Edge colour: theme-aware base → warm glow near plume */\n  vec3 edgeLit = mix(COL_WARM, COL_FIRE, heat);\n  vec3 edgeDim;\n  vec3 edgeCol;\n  vec3 tileFill;\n  if (u_isDark) {\n    edgeDim  = vec3(0.08);              /* dark grey edges */\n    edgeCol  = mix(edgeDim, edgeLit, heat);\n    tileFill = vec3(0.0);               /* black fill */\n  } else {\n    edgeDim  = vec3(1.0);               /* invisible when cold */\n    edgeCol  = mix(edgeDim, edgeLit, heat);\n    tileFill = vec3(1.0);               /* white fill */\n  }\n  vec3 tileCol = mix(tileFill, edgeCol, edgeLine);\n\n  /* ---- 3. Composite ovals over tiles -------------------------- */\n  float a = u_intensity * 0.8;\n  vec3 col = tileCol;\n  col = mix(col, COL_HAZE, o1 * (u_isDark ? 0.65 : 0.85) * a);\n  col = mix(col, COL_WARM, o2 * a);\n  col = mix(col, COL_FIRE, o3 * a);\n  col = mix(col, COL_CORE, o4 * a);\n  /* Hex edges on top for warmth near core */\n  col = mix(col, edgeCol * (u_isDark ? 1.3 : 1.1), edgeLine * heat * 0.35);\n\n  /* ---- 4. Heat shimmer ---------------------------------------- */\n  /*\n   * Noise-based brightness wobble — two FBM samples at\n   * different scales and scroll speeds break up any\n   * visible pattern.  Multiplicative so it darkens/\n   * brightens existing colour like real refraction.\n   * Strongest at the glow edges, invisible at core & cold.\n   */\n  float shimMask = smoothstep(0.0, 0.15, heat) * smoothstep(1.0, 0.6, heat);\n  float n1 = fbm2(uv * 8.0 + vec2(u_time * 0.4, u_time * -0.6));\n  float n2 = fbm2(uv * 14.0 + vec2(u_time * -0.3, u_time * 0.5));\n  float shim = (n1 - 0.5) + (n2 - 0.5) * 0.6;\n  col *= 1.0 + shim * shimMask * 0.35;\n\n  /* ---- 5. Vignette (dark mode only) --------------------------- */\n  /* Edge darkening blends with dark backgrounds but creates\n     a visible dark overlay on light pages — skip it there. */\n  if (u_isDark) {\n    float vig = smoothstep(0.0, 0.35,\n      min(uv.x, min(1.0 - uv.x, 1.0 - uv.y)));\n    col *= 0.65 + 0.35 * vig;\n  }\n\n  /* ---- 6. Alpha ----------------------------------------------- */\n  float topFade = smoothstep(1.0, 0.80, uv.y);\n\n  float ovalAlpha;\n  if (u_isDark) {\n    ovalAlpha = min(o1 * 0.6 + o2 * 0.6 + o3 + o4, 1.0);\n  } else {\n    /* Light mode: no haze alpha — pink tints the flame\n       area via colour mix only (o2/o3/o4 provide alpha) */\n    ovalAlpha = min(o2 * 0.4 + o3 + o4, 1.0);\n  }\n\n  float alpha = ovalAlpha * u_intensity * topFade;\n  /* Extend alpha for hex tiles near the flame */\n  float tileAlpha = u_isDark ? heat * 0.6 : heat * heat * heat * 0.3;\n  alpha = max(alpha, tileAlpha * topFade);\n\n  gl_FragColor = vec4(col, alpha);\n}\n",transparent:!0,depthTest:!1,uniforms:this.uniforms});let a=new e.Mesh(s,this.material);this.scene.add(a)}}let tM=(0,m.memo)(function(n){let{isHeavy:i=!1,maxWidthClass:s="max-w-breakout"}=n,{resolvedTheme:a}=(0,A.useTheme)(),o="dark"===a,[r,l]=(0,m.useState)(!1),c=(0,m.useRef)(null),u=(0,m.useRef)(null),d=(0,m.useRef)(null),h=(0,m.useRef)(!1),p=(0,eC.useRocketStore)(e=>e.seq),g=(0,eC.useRocketStore)(e=>e.command),v=(0,m.useCallback)(()=>{l(!1)},[]),f=(0,m.useCallback)(()=>d.current?Promise.resolve(d.current):h.current?Promise.reject(Error("Three.js load already in progress")):(h.current=!0,(!tE.promise&&(tE.promise=e.A(131527))
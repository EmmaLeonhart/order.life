  "datatype": "time",
  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "التاريخ الذي عُرف فيه أن الشخص كان نشطا أو كان على قيد الحياة، حين لا يتم توثيق تاريخ الميلاد أو الوفاة"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "пэрыяд, у які асоба дзейнічала ці жыла, калі невядомыя даты нараджэньня або сьмерці"
    },
    "bg": {
      "language": "bg",
      "value": "година или период в нечия биография, за които има доказателства, че човекът е живял, бил е активен или е постигнал своя разцвет"
    },
    "ca": {
      "language": "ca",
      "value": "data en la qual se sap que una persona estava activa o en vida, quan la data de naixement o defunció son desconegudes"
    },
    "cs": {
      "language": "cs",
      "value": "datum, kdy osoba s nejistým datem narození a/nebo úmrtí byla aktivní"
    },
    "cy": {
      "language": "cy",
      "value": "Cyfnod blodeuo: defnyddiwch blwyddyn, degawd neu ganrif"
    },
    "da": {
      "language": "da",
      "value": "tidspunkt, hvor en person vides at have været aktiv eller levende, hvis fødselsdato eller dødsdato ikke er kendt"
    },
    "dag": {
      "language": "dag",
      "value": "dabisili shɛli niri ni beni bee n be o nyevuli ni di yi niŋ ka kpibu bee doɣim bi sabi doya"
    },
    "de": {
      "language": "de",
      "value": "Wirkungsjahr einer Person, von der weder Geburts- noch Todesdatum bekannt ist (mehrfache Werte sind möglich)"
    },
    "el": {
      "language": "el",
      "value": "περίοδος κατά την οποία το πρόσωπο ήταν γνωστό ότι ήταν ενεργό ή έζησε, όταν δεν είναι τεκμηριωμένος χρόνος γέννησης ή θανάτου"
    },
    "en": {
      "language": "en",
      "value": "date when the person was known to be active or alive, when birth or death not documented"
    },
    "en-gb": {
      "language": "en-gb",
      "value": "when the person was known to be active or alive, when birth or death not documented (contrast with P585 and P746). Can have multiple values if the subject has produced works in multiple years"
    },
    "es": {
      "language": "es",
      "value": "fecha en la que una persona de la que se desconoce su nacimiento o defunción se tiene constancia que estaba activa"
    },
    "ext": {
      "language": "ext",
      "value": "fecha ena que una pessona dela que se desconoci la su nacencia o defunción se tieni costancia qu'estava ativa"
    },
    "fa": {
      "language": "fa",
      "value": "(مخالف خصوصیت P585 و P746) می‌تواند چند مقدار داشته باشد"
    },
    "fi": {
      "language": "fi",
      "value": "aika, jolloin tekijän tuotanto on syntynyt, erityisesti, jos syntymä- ja kuoliaika eivät ole tiedossa"
    },
    "fr": {
      "language": "fr",
      "value": "date à laquelle une personne a été active ou vivante (à utiliser quand les dates de naissance et/ou de mort sont inconnues), ce qui permet de présupposer une période où elle vivait"
    },
    "gl": {
      "language": "gl",
      "value": "data na que se sabe que a persoa estaba activa ou con vida nos casos en que a data de nacemento ou morto son descoñecidas"
    },
    "he": {
      "language": "he",
      "value": "התקופה בה פעל האדם"
    },
    "hu": {
      "language": "hu",
      "value": "az a dátum, amikor a személyről ismert (volt), hogy aktív vagy életben van/volt még (hasznos pl. olyankor, ha a születés vagy halál éve nincs dokumentálva)"
    },
    "ig": {
      "language": "ig",
      "value": "Oge ndụ ma ọ bu notable ihe onye ana ekwu maka ya,mgbe akowapụ̀taghị oge ndụ ma ọ bụ oge ọnwụ Onye."
    },
    "it": {
      "language": "it",
      "value": "data alla quale si ha prova dell'attività di un soggetto del quale non siano noti data di nascita né di morte"
    },
    "ja": {
      "language": "ja",
      "value": "生没年不詳の場合、この人物が活躍していたとわかる時期"
    },
    "kk": {
      "language": "kk",
      "value": "адамның белгілі бір салада қызмет кеткен кезеңі"
    },
    "ko": {
      "language": "ko",
      "value": "항목 주제인, 태어난 날이나 사망한 날이 알려지지 않은 인물이 활동한 시기"
    },
    "nb": {
      "language": "nb",
      "value": "tid da det er kjent at en person var virksom, for personer der fødsels- eller dødsår er ukjent"
    },
    "nds": {
      "language": "nds",
      "value": "Tied, von de bekannt is, dat de Persoon do aktiv weer"
    },
    "nl": {
      "language": "nl",
      "value": "datum waarvan bekend is dat persoon actief of in leven is, wanneer de data van geboorte of dood niet bekend zijn"
    },
    "pl": {
      "language": "pl",
      "value": "okres, kiedy wiadomo, że osoba działała lub żyła gdy nie jest znana data jej narodzin i śmierci"
    },
    "pt": {
      "language": "pt",
      "value": "data quando sabe-se que a pessoa estava viva, quando nascimento e/ou morte não estão documentados"
    },
    "ro": {
      "language": "ro",
      "value": "perioada în care persoana a trăit, când detalii privind anii de naștere și deces nu sunt cunoscute"
    },
    "ru": {
      "language": "ru",
      "value": "даты, когда персона проявляла активность в соответствующей деятельности. Используйте P2031 и P2032, если нужно указать продолжительный период"
    },
    "sv": {
      "language": "sv",
      "value": "tid då en person belagts som aktiv, för personer vars födelse- och dödsår är okända"
    },
    "tr": {
      "language": "tr",
      "value": "bir kişinin aktif veya hayatta olduğu tarih (doğum ve / veya ölüm tarihleri ​​bilinmediğinde kullanılacaktır), bu da yaşadıkları bir dönemi önceden varsaymayı mümkün kılar"
    },
    "uk": {
      "language": "uk",
      "value": "дата, на яку людина була певно активна чи жива, якщо дати народження або смерті невідомі"
    },
    "vi": {
      "language": "vi",
      "value": "thời gian một người được cho là sinh sống, khi năm sinh và mất không rõ"
    },
    "zh": {
      "language": "zh",
      "value": "知道該人活躍或活著的日期，出生或死亡未記錄的日期"
    },
    "zh-hans": {
      "language": "zh-hans",
      "value": "在没有确切的出生和逝世日期的情况下，该人的在世时间（与P585和P746对比）。"
    }

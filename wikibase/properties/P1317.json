        "id": "P1317$FD1A6BB9-3783-443C-8008-61EE14ED5E9E",
        "mainsnak": {
          "datavalue": {
            "type": "monolingualtext",
            "value": {
              "language": "ro",
              "text": "Se folosește în loc de P585 și P746 (proprietățile anilor de viață). A se utiliza P2031 și P2032 dacă se cunosc limitele temporale ale perioadei de activitate."
            }
          },
          "hash": "ba4e66038955f8f6743e16835d774bb654948941",
          "property": "P2559",
          "snaktype": "value"
        },
        "rank": "normal",

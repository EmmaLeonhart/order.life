  "datatype": "string",
  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "عنوان URL لصفحة الويب؛ قالب URI الذي يمكن من خلاله استبدال \"$1\" تلقائيًا بقيمة الخاصية الفعالة على العناصر. إذا أصبح الموقع غير متصل بالإنترنت، فاضبطه على رتبة موقوفة. إذا تغير عنوان URL الخاص بالتنسيق، أضف عبارة جديدة بالرتبة المفضلة"
    },
    "ast": {
      "language": "ast",
      "value": "cadena d'estilu URL, como «http://viaf.org/viaf/$1/», onde «$1» pue trocase automáticamente pol valor efeutivu de la propiedá (usar en declaraciones de propiedaes)"
    },
    "be": {
      "language": "be",
      "value": "маска URL, у якім знакі $ і 1 разам пазначаюць значэнне, якое падстаўляецца"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "маска URL, напрыклад «http://viaf.org/viaf/$1/», у якой «$1» аўтаматычна замяняецца на падстаўленае значэньне"
    },
    "cs": {
      "language": "cs",
      "value": "šablona pro URL, ze které se nahrazením „$1“ za identifikátor získá adresa webové stránky pro příslušný identifikátor"
    },
    "da": {
      "language": "da",
      "value": "URL-agtig streng hvor en del kan blive substitueret"
    },
    "de": {
      "language": "de",
      "value": "URL-ähnliche Zeichenkette, wie „https://wikidata.org/wiki/$1/“, bei der „$1“ automatisch ersetzt wird mit dem tatsächlichen Eigenschaftswert eines Datenobjekts (genutzt bei der Definition von Eigenschaften)."
    },
    "en": {
      "language": "en",
      "value": "web page URL; URI template from which “$1” can be automatically replaced with the effective property value on items. If the site goes offline, set it to deprecated rank. If the formatter URL changes, add a new statement with preferred rank"
    },
    "es": {
      "language": "es",
      "value": "un patrón de URL genérico, personalizable para cada declaración según el valor introducido (uso en declaraciones de propiedades, ejemplo: \"http://www.wikidata.org/wiki/$1\", donde \"$1\" cambiará al valor de la propiedad con este formato de URL)"
    },
    "eu": {
      "language": "eu",
      "value": "URL generiko bat parametroekin agertzen den katea"
    },
    "ext": {
      "language": "ext",
      "value": "un patrón de URL genéricu, pessonalizabli pa ca declaramientu sigún el valol entroduzíu (gastu en declaramientus de propiedais, exempru: \"http://www.wikidata.org/wiki/$1\", aondi \"$1\" muará'l valol dela propiedá con esti hormatu de URL)"
    },
    "fa": {
      "language": "fa",
      "value": "نشانی اینترنتی‌ وبگاهی که خصوصیت مورد نظر از آن برداشته می‌شود"
    },
    "fi": {
      "language": "fi",
      "value": "verkkosivun URL, johon voidaan automaattisesti korvata muuttujan arvo kohtaan \"$1\""
    },
    "fr": {
      "language": "fr",
      "value": "chaîne représentant une URL générique avec paramètres (à utiliser dans les déclarations sur les propriétés)"
    },
    "he": {
      "language": "he",
      "value": "כתובת אתר של דף אינטרנט; תבנית URI שממנה ניתן להחליף אוטומטית את \"$1\" בערך המאפיין האפקטיבי בפריטים. אם האתר עובר למצב לא מקוון, הגדר אותו לדירוג שהוצא משימוש. אם כתובת האתר של הפורמט משתנה, הוסף הצהרה חדשה עם דירוג מועדף"
    },
    "hu": {
      "language": "hu",
      "value": "URL-szerű karaktersor, pl. „http://viaf.org/viaf/$1”, ahol a „$1” automatikusan kicserélődik a tulajdonság értékére (tulajdonságok állításainál használd)"
    },
    "id": {
      "language": "id",
      "value": "string berupa URL, yang \"$1\" dari diganti dengan nilai atribut pada butir yang benar"
    },
    "ig": {
      "language": "ig",
      "value": "ibe weebụ URL; Nleba URI nke nwere ike dochie \"$1\" na-akpaghị aka na uru akụrụngwa dị irè na ihe. Ọ bụrụ na saịtị ahụ na-anọghị n'ịntanetị, tọọ ya ka ọ bụrụ ọkwa ewepụrụ. Ọ bụrụ na URL onye nhazi agbanwe, tinye nkwupụta ọhụrụ nwere ọkwa masịrị"
    },
    "it": {
      "language": "it",
      "value": "una stringa tipo URL che contiene un segnaposto $1 che opportunamente sostituito genera un indirizzo URL dereferenziabile (cliccabile); usata nelle dichiarazioni relative a proprietà, es http://viaf.org/viaf/$1/"
    },
    "ja": {
      "language": "ja",
      "value": "「http://viaf.org/viaf/$1/」のようなURLの形をした文字列で、「$1」が項目におけるそのプロパティの実効値で自動的に置換できる（プロパティに関する文で使われる）。もしサイトが閉鎖された場合は、ランクを「非推奨」に変更します。もし新しいURLへサイトが移動した場合は、新たにデータを追加して、ランクを「推奨」にします。"
    },
    "ko": {
      "language": "ko",
      "value": "해당 속성의 값(식별자)에 상응하는 정보를 볼 수 있는 URL의 서식"
    },
    "ml": {
      "language": "ml",
      "value": "വെബ് പേജോ  URL എന്നിവ, \"$1\"  എന്ന വേരിയബിൾ മാറ്റം വരുത്താവുന്ന ഒരു ടെമ്പ്‌ലേറ്റ്. ഉദാഹരണമായി (http://viaf.org/viaf/$1/), ഇതിൽ $1\" നു പകരം VIAF ID ഉപയോഗിച്ച് ശരിക്കുള്ള  URL നിർമിക്കാം."
    },
    "ms": {
      "language": "ms",
      "value": "Templat URI di mana \"$1\" boleh digantikan secara automatik dengan nilai yang sesuai pada item"
    },
    "nb": {
      "language": "nb",
      "value": "URL-aktig streng, som f.eks. «http://viaf.org/viaf/$1/», der $1 automatisk kan erstattes med egenskapens verdi. (Bruk som utsagn for egenskaper.)"
    },
    "pl": {
      "language": "pl",
      "value": "ciąg w formacie URL, gdzie za \"$1\" będzie można podstawić wartość właściwości w elementach"
    },
    "pt": {
      "language": "pt",
      "value": "string do tipo URL, tal como \"http://viaf.org/viaf/Noutras línguas/\", a partir da qual  \"Noutras línguas\" pode ser substituído automaticamente pelo valor efetivo da propriedade nos itens (utilizado em declarações em propriedades)"
    },
    "pt-br": {
      "language": "pt-br",
      "value": "string do tipo URL, tal como \"http://viaf.org/viaf/$1/\", a partir da qual \"$1\" pode ser substituído automaticamente pelo valor efetivo da propriedade nos itens (utilizado em declarações de propriedades)"
    },
    "ro": {
      "language": "ro",
      "value": "în proprietăți, modelul adresei URL, în care expresia „$1” este înlocuită cu valori concrete"
    },
    "ru": {
      "language": "ru",
      "value": "на сущностях-свойствах: адрес страницы для веб браузеров; маска URL, в которой \"$1\" обозначает подставляемое значение"
    },
    "sl": {
      "language": "sl",
      "value": "URL spletnega mesta; predloga URI, pri kateri se lahko »$1« samodejno zamenjava z veljavno lastnostjo predmeta. Če spletišče ni več navoljo, ga nastavite na »opuščeno mesto«. Če se oblikovalnik URL-ja spremeni, dodajte novo izjavo z želenim mestom."
    },
    "sv": {
      "language": "sv",
      "value": "URL-lik sträng, t.ex. \"http://viaf.org/viaf/$1/\", från vilket $1 automatiskt kan ersättas av egenskapens värde. (Använd för uttalanden i egenskaper)"
    },
    "tg": {
      "language": "tg",
      "value": "ниқоби URL, ки \"$1\" маънои вироишшударо нишон медиҳад"
    },
    "tr": {
      "language": "tr",
      "value": "genellikle dizin web sitelerinde çok sık değişmese de, değişebilen URL adresinin formatı. Site çevrimdışı durumdaysa, kullanımdan kaldırıldığı belirtin"
    },
    "uk": {
      "language": "uk",
      "value": "маска URL для властивості, у якій '$1' позначає значення властивості елемента, на якому використана властивість. Якщо сайт неактивний, встановіть для нього застарілий ранг. Якщо шаблон URL змінюється, додайте нове твердження з пріоритетним рангом."
    },
    "uz": {
      "language": "uz",
      "value": "veb-sahifaning URL manzili;  URI shabloni, undan \"$1\" avtomatik ravishda elementlardagi samarali xususiyat qiymati bilan almashtirilishi mumkin. Agar sayt oflayn bo'lsa, uni eskirgan darajaga o'rnating. Agar formatlovchining URL manzili o'zgarsa, a"
    },
    "zh": {
      "language": "zh",
      "value": "用于搭配标识符以生成网页链接的固定字符串"
    },
    "zh-hant": {
      "language": "zh-hant",
      "value": "一個固定的字串，用於搭配不同的識別碼以生成網頁連結"
    }
  },

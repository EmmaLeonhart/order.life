  "descriptions": {
    "en": {
      "language": "en",
      "value": "this is a register of names found over time for old places in a parish that is managed by the Swedish Institute for Language and Folklore - SOFI"
    },
    "sv": {
      "language": "sv",
      "value": "register över platser funna i en socken som administreras Institutet för språk och folkminnen"
    },

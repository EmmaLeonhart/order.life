  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "مُعرِّف للضبط الاستنادي خاص بِعميل (فنَّان أو مُبتكر أو مالك حقوق تأليف…إلخ. يصح أن يكون شخصًا طبيعيًّا أو معنويًّا كمؤسسةٍ أو جهةٍ ما) في مجموعة المتاحف الوطنية التاريخية في السويد"
    },
    "az": {
      "language": "az",
      "value": "İsveç Milli Tarix Muzeylərinin kolleksiyalarına daxil olmaq üçün səlahiyyət identifikasiyası"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "нарматыўны ідэнтыфікатар агента (артыста, уласьніка, творцы — як асобы, так і ўстановы) ў зборах Нацыянальнага гістарычнага музэю Швэцыі"
    },
    "en": {
      "language": "en",
      "value": "authority identification for an entry in the collections of the National Historical Museums of Sweden"
    },
    "fr": {

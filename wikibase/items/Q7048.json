  "descriptions": {
    "en": {
      "language": "en",
      "value": "Prince Mayowa (Mayowa no Okimi; born in 450, and died in 456) appeared in Kiki, (\"Kojiki\" [A Record of Ancient Matter] and the \"Nihonshoki\" [Chronicles of Japan]) as an Imperial family (royal family) in fifth century in Japan."
    },
    "ja": {
      "language": "ja",
      "value": "日本の皇族"
    },
    "sr": {
      "language": "sr",
      "value": "Princ Mayowa (Mayowa no Okimi; rođen 450, preminuo 456) pojavljuje se u Kiki (\"Kojiki\" [Zapis drevnih događaja] i \"Nihonshoki\" [Hronike Japana]) kao član carske porodice (kraljevske porodice) u Japanu u petom veku."
    }
  },

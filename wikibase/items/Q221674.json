  "descriptions": {
    "af": {
      "language": "af",
      "value": "die mees onlangse vrou van wie alle mense vandag deur hul moeder afstam, en deur die moeder van hulle moeder ensovoorts, totdat alle linies na een vrou lei"
    },
    "ar": {
      "language": "ar",
      "value": "علم وراثة الميتوكندريا"
    },
    "be": {
      "language": "be",
      "value": "імя, дадзенае ў папулярнай культуры жанчыне, якая жыла ў Афрыцы каля 200 000 гадоў таму, ад якой сучаснае чалавецтва атрымала ў спадчыну мітахандрыяльную ДНК (арыгінальны тэрмін, прапанаваны першаадкрывальнікам Аланам Вільсанам — Lucky Mother — У..."
    },
    "bg": {
      "language": "bg",
      "value": "идея в човешката генетика за матрилинеен най-скорошен общ прародител (на английски език MRCA) на всички живи хора в света, тоест най-скорошната жена, от която произлизат всички живи хора по непрекъсната линия чрез своите майки, чрез майките на св..."
    },
    "bs": {
      "language": "bs",
      "value": "drevna \"pramajka\" današnjih ljudi, od koje potiču njihove majke"
    },
    "ca": {
      "language": "ca",
      "value": "Genealogia genètica"
    },
    "cs": {
      "language": "cs",
      "value": "označení pro ženu, která je v mateřské linii společným předkem všech dnes žijících lidí"
    },
    "da": {
      "language": "da",
      "value": "Evolutionsteori"
    },
    "de": {
      "language": "de",
      "value": "Erklärungsmodell der Archäogenetik"
    },
    "el": {
      "language": "el",
      "value": "Φυλογενετική"
    },
    "en": {
      "language": "en",
      "value": "matrilineal most recent common ancestor of all living humans"
    },
    "eo": {
      "language": "eo",
      "value": "plej lasta komuna prapatrino de ĉiuj vivantaj homoj"
    },
    "es": {

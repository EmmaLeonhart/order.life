  "descriptions": {
    "en": {
      "language": "en",
      "value": "daimyo of the early Edo period; 1st lord of Marugame"
    },
    "ja": {
      "language": "ja",
      "value": "江戸時代前期の大名。播磨龍野藩主、讃岐丸亀藩初代藩主。丸亀藩京極家3代。安毛高政の長男。母は家女房あるいは本庄氏。従五位下・刑部大輔。子に熊子"
    },
    "pt-br": {
      "language": "pt-br",
      "value": "Líder do Clã Kyōgoku e daimyo durante o xogunato Tokugawa"
    }

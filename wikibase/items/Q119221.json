      "language": "he",
      "value": "נכדתו של נביא האסלאם מוחמד ובתו של האמאם עלי"
    },
    "it": {
      "language": "it",
      "value": "è stata la quartogenita (la seconda delle femmine) di ʿAlī ibn Abī Tālib - quarto dei \"califfi \"ortodossi\" e primo Imam dello sciismo - e di Fāṭima, figlia di Maometto"
    },
    "ks": {
      "language": "ks",
      "value": "کورِ ہِنٛز کوٗر مُحمد ﷺ سٕنٛز"

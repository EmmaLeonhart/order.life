  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "سبطة النبي محمد وزوجة عمر بن الخطاب وبنت علي بن أبي طالب وفاطمة وأخت الحسن والحسين وزينب"
    },
    "az": {
      "language": "az",
      "value": "Əlinin və Fatimənin qızı, Ömərin həyatyoldaşı."
    },
    "ca": {
      "language": "ca",
      "value": "filla d'Alí ibn Abi-Tàlib"
    },
    "de": {

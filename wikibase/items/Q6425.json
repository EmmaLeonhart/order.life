  "descriptions": {
    "el": {
      "language": "el",
      "value": "Κινέζα αυτοκράτειρα"
    },
    "en": {
      "language": "en",
      "value": "Legendary Chinese empress, consort of the Yellow Emperor and inventor of silk and sericulture"
    },
    "fa": {
      "language": "fa",
      "value": "شهبانوی چینی"
    },
    "he": {
      "language": "he",
      "value": "קיסרית סינית, אשתו של הקיסר הצהוב"
    },
    "it": {
      "language": "it",
      "value": "imperatrice cinese"
    },
    "sl": {
      "language": "sl",
      "value": "legendarna kitajska cesarica, soproga Rumenega cesarja ter izumiteljica svile in serikulture"
    },
    "sv": {
      "language": "sv",
      "value": "legendarisk kinesisk kejsarinna"
    },
    "tr": {
      "language": "tr",
      "value": "Çin mitolojisinde efsanevi kraliçe"
    },
    "vi": {
      "language": "vi",
      "value": "Là một nhân vật nữ trong truyền thuyết Trung Quốc. Theo đó, bà là vợ cả của Hoàng Đế Công Tôn Hiên Viên và là người đầu tiên chế ra việc nuôi tằm với điển tích Luy Tổ thủy tằm"
    },
    "zh": {
      "language": "zh",
      "value": "五帝人﹐女。古今女史﹐集韻﹐名媛彙詩﹐名媛詩歸有著錄。"
    },
    "zh-hans": {
      "language": "zh-hans",
      "value": "五帝人﹐女。古今女史﹐集韵﹐名媛汇诗﹐名媛诗归有著录。"
    },
    "zh-hant": {
      "language": "zh-hant",
      "value": "五帝人﹐女。古今女史﹐集韻﹐名媛彙詩﹐名媛詩歸有著錄。"
    }
  },

  "descriptions": {
    "de": {
      "language": "de",
      "value": "CYPARISSI , órum , des Eteokles Töchter, tanzeten ungefähr mit einander, fielen aber dabey in einen Brunn und kamen darinnen um, wofür sie die Tellus, aus Mitleiden, in Cypressenbäume verwandelte. Didymus ap. Farnab. ad Ovid. Metam . X. v. 121 ."
    },
    "en": {
      "language": "en",
      "value": "daughter of Eteocles in Greek mythology"
    },

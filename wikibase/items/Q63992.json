  "descriptions": {
    "en": {
      "language": "en",
      "value": "[松平乗命] daimyo of Iwamura"
    },
    "ja": {
      "language": "ja",
      "value": "江戸時代後期の大名。美濃岩村藩8代藩主（最後）。乗政流大給松平家8代、子爵岩村松平家初代。従五位下・能登守。江戸幕府 大坂加番、奏者番、陸軍奉行。維新後子爵。松平乗喬の次男"
    },
    "tr": {
      "language": "tr",
      "value": "Japon derebeyi/daimyō (1848 – 1905)"
    }

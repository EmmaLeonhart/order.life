  "descriptions": {
    "ca": {
      "language": "ca",
      "value": "Tercer fill bastard d'Otomo Yoshinori. Vasall del clan Hosokawa. Fill de Matsuno Chikatsuyu (segon fill, gran camarlenc del shogunat, resident de Ninomaru i comandant avançat d'artilleria)"
    },
    "es": {
      "language": "es",
      "value": "Tercer hijo bastardo de Otomo Yoshinori. Vasallo del clan Hosokawa. Hijo de Matsuno Chikatsuyu (segundo hijo, gran chambelán del shogunato, residente de Ninomaru y comandante avanzado de artillería)"
    },
    "ja": {
      "language": "ja",
      "value": "大友義統の庶子三男。細川氏家臣。右京進。子に松野親冬（次男、幕府 大番、二の丸留守居・先手鉄砲頭）"
    }

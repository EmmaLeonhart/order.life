  "descriptions": {
    "de": {
      "language": "de",
      "value": "Gouverneur von Idumäa, Schwager Herodes des Großen"
    },
    "el": {
      "language": "el",
      "value": "1ος σύζυγος της Σαλώμης Α΄"
    },
    "en": {
      "language": "en",
      "value": "associate of Herod the Great: who made Costobarus governor of Idumea, and second husband of Herod's sister Salome I"
    },
    "fr": {
      "language": "fr",
      "value": "deuxième mari de Salomé I"
    },
    "he": {
      "language": "he",
      "value": "מושל אדום ועזה מטעם הורדוס ובעלה של שלומית אחותו"
    },
    "nl": {
      "language": "nl",
      "value": "gouverneur van Idumea en Gaza"
    },
    "pt": {
      "language": "pt",
      "value": "de uma antiga família sacerdotal edomita, anterior ao tempo em que o hasmoneu Hircano forçou os naturais da Idumeia a se converterm ao Judaísmo"
    }
  },

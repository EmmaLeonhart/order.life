  "descriptions": {
    "ba": {
      "language": "ba",
      "value": "рим мифологияһында үҫемлектәр һәм хайуандар донъяһы, һунар, гүзәллек һәм уңдырышлылыҡ алиһәһе"
    },
    "ca": {
      "language": "ca",
      "value": "deessa romana dels boscos i de la caça"
    },
    "cs": {
      "language": "cs",
      "value": "římská bohyně lovu a měsíce"
    },
    "da": {
      "language": "da",
      "value": "romersk gudinde for jagt, månen og fødsel"
    },
    "de": {
      "language": "de",
      "value": "römische Göttin"
    },
    "en": {
      "language": "en",
      "value": "goddess of the hunt, the moon and birthing, equated with the Greek goddess Artemis"
    },
    "eo": {
      "language": "eo",
      "value": "Romia diino de ĉasado, Luno, kaj nasko; identigita kun la helena diino Artemiso"
    },

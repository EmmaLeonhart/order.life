  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "أبو عمرو عاصم بن عمر بن الخطاب تابعي مدني، وأحد رواة الحديث النبوي، وهو جد الخليفة الأموي عمر بن عبد العزيز لأمه"
    },
    "az": {
      "language": "az",
      "value": "Tanınmış hədis ravisi, xəlifə Ömərin oğlu"
    },
    "bn": {
      "language": "bn",
      "value": "হাদিস বর্ণনাকারী"
    },
    "ca": {
      "language": "ca",
      "value": "tabií i muhàddith (transmissor i/o estudiós dels hadits)"
    },
    "ce": {
      "language": "ce",
      "value": "мухьаддис"
    },
    "da": {
      "language": "da",
      "value": "muhaddith"
    },
    "en": {
      "language": "en",
      "value": "Son of caliph Umar and hadith scholar (c.628–c.689)"
    },
    "es": {
      "language": "es",
      "value": "muhadiz"
    },
    "fa": {
      "language": "fa",
      "value": "عاصم بن عمر (به عربی: عاصم بن عمر؛ ۶۸۹–۶۲۸) پسر خلیفه دوم عمر بن خطاب و همسرش جمیله بنت ثابت بود"
    },
    "nl": {
      "language": "nl",
      "value": "muhaddith"
    },
    "ru": {
      "language": "ru",
      "value": "Мухаддис"
    },
    "sv": {
      "language": "sv",
      "value": "muhaddith"
    },
    "tg": {
      "language": "tg",
      "value": "муҳаддис"
    },
    "ur": {
      "language": "ur",
      "value": "جمیلہ بنت ثابت اور دوسرے خلیفہ راشد حضرت عمر بن خطاب کے بیٹے"
    }
  },

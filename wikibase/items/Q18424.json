  "descriptions": {
    "en": {
      "language": "en",
      "value": "daimyo of the early Edo period; 1st lord of Iwakitaira"
    },
    "ja": {
      "language": "ja",
      "value": "戦国時代から江戸時代前期の武将、大名。上総佐貫藩主、陸奥磐城平藩主。延岡藩内藤家宗家初代。従四位下、左馬助。内藤家長の長男。子に内藤政次（次男）、内藤政重（三男）"
    },
    "nl": {
      "language": "nl",
      "value": "commandant"
    }

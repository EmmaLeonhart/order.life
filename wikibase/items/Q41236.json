  "descriptions": {
    "ja": {
      "language": "ja",
      "value": "安土桃山時代から江戸時代初期の武将。結城氏、佐竹氏の家臣。従五位下・修理大夫。常陸下妻城主。子に多賀谷忠経（子孫は多賀谷泰経-多賀谷経政-多賀谷経栄）、多賀谷茂光、菅谷経晃（三郎）"
    },
    "nl": {
      "language": "nl",
      "value": "commandant"
    }

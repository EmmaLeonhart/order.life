  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "شخصية أسطورية إغريقية"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "багіня грэцкай міталёгіі"
    },
    "bn": {
      "language": "bn",
      "value": "গ্রিক পুরাণের প্রেম, আনন্দ, আবেগ এবং সৌন্দর্যের দেবী"
    },
    "ca": {
      "language": "ca",
      "value": "deessa grega de l'amor, la bellesa, el plaer i la procreació"
    },
    "cs": {
      "language": "cs",
      "value": "řecká bohyně lásky a krásy"
    },
    "da": {
      "language": "da",
      "value": "gudinde for kærlighed, skønhed og frugtbarhed i græsk mytologi"
    },
    "de": {
      "language": "de",
      "value": "Göttin der Liebe, Schönheit und Begierde in der griechischen Mythologie"
    },
    "el": {
      "language": "el",
      "value": "θεά της αγάπης, της ομορφιάς και της τεκνοποίησης στην ελληνική μυθολογία"
    },
    "en": {
      "language": "en",
      "value": "Greek goddess of love, beauty, pleasure, and procreation"
    },
    "en-gb": {
      "language": "en-gb",
      "value": "Greek goddess of love, beauty, pleasure, and procreation"
    },
    "eo": {
      "language": "eo",
      "value": "helena diino de amo kaj belo"
    },
    "es": {
      "language": "es",
      "value": "antigua diosa griega del amor y la belleza"
    },
    "et": {
      "language": "et",
      "value": "vanakreeka armastusjumalanna"
    },
    "fa": {
      "language": "fa",
      "value": "الهۀ عشق در یونان باستان"
    },
    "fi": {
      "language": "fi",
      "value": "kreikkalaisen mytologian jumalatar"
    },
    "fr": {
      "language": "fr",
      "value": "déesse de l'Amour dans la religion grecque antique et la mythologie grecque"
    },
    "gl": {
      "language": "gl",
      "value": "deusa grega do amor, equivalente á Venus romana"
    },
    "he": {
      "language": "he",
      "value": "אלת האהבה היוונית הקדומה"
    },
    "hr": {
      "language": "hr",
      "value": "grčka božica ljubavi, ljepote i seksa, žena boga Hefesta"
    },
    "hu": {
      "language": "hu",
      "value": "a szépség és a szerelem görög istennője"
    },
    "id": {
      "language": "id",
      "value": "Dewi cinta, kecantikan, seksualitas, kenikmatan, dan prokreasi"
    },
    "ilo": {

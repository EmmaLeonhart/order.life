  "descriptions": {
    "en": {
      "language": "en",
      "value": "Japanese feudal lord of the Edo period."
    },
    "ja": {
      "language": "ja",
      "value": "江戸時代前期の大名。播磨平福藩主、播磨赤穂藩2代藩主（遺領相続、改易）。輝興系池田家初代。池田輝政の六男。従五位下、従四位下、右近大夫"
    },
    "zh": {
      "language": "zh",
      "value": "江户时代的日本封建领主"
    }

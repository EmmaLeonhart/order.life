  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "سيد من سادات مكة و سيد قبائل كنانة في حرب الفجار و هو جد فرع بني أمية (الأمويين) من قبيلة قريش"
    },
    "en": {
      "language": "en",
      "value": "father of Abu Sufyan and Arwa"
    },

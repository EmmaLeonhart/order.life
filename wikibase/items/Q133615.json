  "descriptions": {
    "de": {
      "language": "de",
      "value": "Nach Cicero ist der dritte Asklepios, der sogenannte »messenische Asklepios«, der Sohn des Arsippos und Arsinoe; vgl. Kleine Pauly, Bd. II, Sp. 37."
    },
    "en": {
      "language": "en",
      "value": "son of Arsippos in Greek mythology"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque, fils d'Arsippos et d'Arsinoé"
    },
    "sl": {
      "language": "sl",
      "value": "po Ciceronu tretji Asklepij, sin Arsipa in Arsinoje"
    }

  "descriptions": {
    "ja": {
      "language": "ja",
      "value": "安土桃山時代から江戸時代前期の大名。豊臣秀吉の一門衆。豊後杵築城主、但馬豊岡亀城主、豊岡藩初代藩主。杉原家次の長男。従五位下伯耆守。子に杉原長俊"
    },
    "nl": {
      "language": "nl",
      "value": "commandant"
    }

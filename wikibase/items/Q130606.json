  "descriptions": {
    "de": {
      "language": "de",
      "value": "Göttinnen in der griechischen Mythologie"
    },
    "en": {
      "language": "en",
      "value": "goddesses of the seasons and the natural portions of time in Greek mythology"
    },
    "eo": {
      "language": "eo",
      "value": "helena diinaro pri tempo kaj sezonoj"
    },

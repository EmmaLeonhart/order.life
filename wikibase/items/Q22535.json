  "descriptions": {
    "ca": {
      "language": "ca",
      "value": "Filla d'Ito Kaimori (senyor de Yamato Uda). Tingué tres fills Sako no boku (1593-10/06/1668, tercera filla, Oken, Gosako no boku, Sako no boku, Sako no boku, Higashifukumonin Wako no kojo)."
    },
    "es": {
      "language": "es",
      "value": "Hija de Ito Kaimori (señor de Yamato Uda). Tuvo tres hijos Sako no boku (1593-10/06/1668, tercera hija, Oken, Gosako no boku, Sako no boku, Sako no boku, Higashifukumonin Wako no kojo)."
    },
    "ja": {
      "language": "ja",
      "value": "伊藤甲斐守（大和宇田の城主）の娘。子に佐古局（1593-1668.6.10、三女、於賢、御佐古の局、佐古の局、東福門院和子女房）"
    }
  },

  "descriptions": {
    "bg": {
      "language": "bg",
      "value": "благородничка от Древен Рим"
    },
    "ca": {
      "language": "ca",
      "value": "la dona de Gai Sili (Caius Silius), governador de la Germania Superior, i complicada junt amb aquest en un càrrec de traïció (any 24)"
    },
    "en": {
      "language": "en",
      "value": "wife of Gaius Silius"
    },
    "it": {
      "language": "it",
      "value": "la moglie di Gaio Silio, console nel 13 e militare sotto Germanico Giulio Cesare, e amica della moglie di Germanico, Agrippina maggiore"
    },
    "nl": {
      "language": "nl",
      "value": "de echtgenote van Gaius Silius Aulus Caecina Largus en werd samen met hem aangeklaagd voor verraad in 24 n"
    }
  },

  "descriptions": {
    "bg": {
      "language": "bg",
      "value": "сръбски жупан, владетел на Хум, Зета и Тревуня (1147/48 - след 1151), както и рашки владетел (около 1155, 1161 – след 1165)"
    },
    "el": {
      "language": "el",
      "value": "Σέρβος ηγεμόνας (ζουπάνος) της Διόκλειας/Ντούκλια (1148-1162), μεγάλος ζουπάνος της Ράσκας 1153-1155 και 1162-1166"
    },
    "en": {
      "language": "en",
      "value": "Serbian ruler"
    },
    "fr": {
      "language": "fr",
      "value": "prince serbe qui fut corégent de Rascie de 1148 à vers 1153, conjointement avec son frère ainé Uroš II Primslav"
    },
    "hr": {
      "language": "hr",
      "value": "Srpski plemić"
    },
    "it": {
      "language": "it",
      "value": "gran principe di Serbia (r. 1162-1165)"
    },
    "nl": {
      "language": "nl",
      "value": "Servisch grootžupan van ongeveer 1161 tot 1165"
    },
    "pl": {
      "language": "pl",
      "value": "najmłodszym synem wielkiego żupana Raszki Urosza I"
    },
    "pt": {
      "language": "pt",
      "value": "príncipe sérvio da Ráscia (na atual Sérvia)"
    },
    "sh": {
      "language": "sh",
      "value": "raški župan, suvladar Raške (1149–1153), te veliki župan Raške (1153–1155 i 1162–1166)"
    },

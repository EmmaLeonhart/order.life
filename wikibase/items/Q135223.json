    },
    "ang": {
      "language": "ang",
      "value": "Mæcedonia cyninȝ"
    },
    "ar": {
      "language": "ar",
      "value": "أحد ملوك مقدونيا الإغريق، ومن أشهر القادة العسكريين والفاتحين عبر التاريخ"
    },
    "as": {
      "language": "as",

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "صحابي، أب أول الخلفاء الراشدين خليفة النبي أبي بكر الصديق رضي الله عنه ، وجد أم المؤمنين و زوجة الرسول محمد صلى الله عليه وسلم الثالثة عائشة رضي الله عنها"
    },

  "descriptions": {
    "ca": {
      "language": "ca",
      "value": "grup de germanes de la mitologia grega"
    },
    "de": {
      "language": "de",
      "value": "in der griechischen Mythologie die neun Töchter des Pieros, die die Musen zum Sangeswettkampf herausforderten, besiegten und zur Strafe in Vögel verwandelt wurden"
    },
    "en": {
      "language": "en",
      "value": "in Greek mythology, nine sisters who defied the Muses in a contest of song and were turned into birds"
    },
    "es": {
      "language": "es",
      "value": "hijas de Píero, rey de Macedonia"
    },
    "fr": {
      "language": "fr",
      "value": "dans la mythologie grecque, les neuf filles de Piéros"
    },
    "he": {
      "language": "he",
      "value": "במיתולוגיה היוונית, תשע אחיות שקראו תגר על המוזות בתחרות שיר ונהפכו לציפורים"
    },
    "it": {
      "language": "it",
      "value": "personaggi mitologici greci, figlie di Pierio"
    },
    "ru": {
      "language": "ru",
      "value": "группа персонажей из древнегреческой мифологии"
    },
    "sl": {
      "language": "sl",
      "value": "v grški mitologiji devet Pierovih hčera, ki so izzvale muze na pevsko tekmovanje, bile poražene in za kazen spremenjene v ptice"
    }
  },

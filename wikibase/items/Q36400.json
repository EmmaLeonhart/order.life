  "descriptions": {
    "en": {
      "language": "en",
      "value": "Sui princess, daughter of Yang Xie and sister of Yang Shanjing, married Yami Khagan and later his sons"
    },
    "vi": {
      "language": "vi",
      "value": "công chúa nhà Tuỳ, con gái Dương Hài, có một anh/em trai tên Dương Thiện Kinh, trước sau làm vợ của bốn Khả-hãn Đông Đột Quyết"
    }

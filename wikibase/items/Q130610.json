  "descriptions": {
    "az": {
      "language": "az",
      "value": "Adrasteya — qədim yunan mifologiyasında qisas ilahəsi. Nemesid ilə eyniləşdirilir. Həmçinin, Zevsi yetişdirən nimfanın adıdır. Kirrakda (Fokida) Adrasteyanın heykəli vardı"
    },
    "en": {
      "language": "en",
      "value": "mountain goddess in Greek mythology"
    },
    "fr": {
      "language": "fr",
      "value": "divinité grecque"
    },
    "he": {
      "language": "he",
      "value": "אלת הרים במיתולוגיה היוונית"
    },
    "it": {
      "language": "it",
      "value": "divinità di montagna della mitologia greca"
    },
    "ka": {
      "language": "ka",
      "value": "ძველ ბერძნულ მითოლოგიაში — ქალღმერთი, ზევსის ქალიშვილი"
    },
    "ru": {
      "language": "ru",
      "value": "в древнегреческой мифологии — богиня, дочь Зевса и Фемиды (или Зевса и Ананке)"
    },
    "sl": {
      "language": "sl",
      "value": "boginja gora v grški mitologiji"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisinde yükseklikler tanrıçası"
    },
    "uk": {
      "language": "uk",
      "value": "богиня"
    }
  },

  "descriptions": {
    "cs": {
      "language": "cs",
      "value": "typ božstev, dvou bratrů"
    },
    "en": {
      "language": "en",
      "value": "supposed twin gods in early Proto-Indo-European mythology, children of Dyēus"
    },
    "es": {
      "language": "es",
      "value": "mitema"
    },
    "he": {
      "language": "he",
      "value": "אלים תאומים כביכול במיתולוגיה הפרוטו-הודו-אירופית המוקדמת, ילדיו של דיאוס"
    },
    "hi": {
      "language": "hi",
      "value": "आद्य भारोपीय मिथक में दैवी यमज या दैवी जुड़वाँ दो अश्वधारी युवा हैं जो या तो देवता है या अर्धदेवता और जो दूसरों की रक्षा करते है या उनका उपचार करके उन्हें नवजीवन देते हैं।"
    },
    "pl": {
      "language": "pl",
      "value": "archetyp w mitologii praindoeuropejskiej"
    }
  },

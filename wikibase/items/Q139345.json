  "descriptions": {
    "ast": {
      "language": "ast",
      "value": "consorte sueca (1001–1117)"
    },
    "be": {
      "language": "be",
      "value": "мясцова шанаваная каталіцкая святая, чый культ зафіксаваны ў сераднявечнай Швецыі"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "каля 1117) — мясцовая шануймая каталіцкая сьвятая, чый культ зафіксаваны ў сераднявечнай Швэцыі"
    },
    "en": {
      "language": "en",
      "value": "local saint whose veneration is attested in late medieval Sweden and whose name was particularly associated with the church in Södertälje in the province of Södermanland and the diocese of Strängnäs"
    },
    "fr": {
      "language": "fr",
      "value": "sainte locale dont le culte est attestée dans la suède médiévale et dont el nom est associé avec l'église de Södertälje dans la province du Södermanland dans le diocèse de Strängnäs"
    },
    "nl": {
      "language": "nl",
      "value": "koningin-gemalin van Zweden in de periode van 1105 tot en met 1117"
    },
    "ru": {
      "language": "ru",
      "value": "шведский антиквар Элиас Пальмскъёльд"
    },
    "sv": {
      "language": "sv",
      "value": "Tälje-bornas skyddshelgon"
    }
  },

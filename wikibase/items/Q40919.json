  "descriptions": {
    "en": {
      "language": "en",
      "value": "daughter of emperor Zhuligu"
    },
    "kk-cyrl": {
      "language": "kk-cyrl",
      "value": "Хуньху ( тюрк.имя Тафгач хатун ? - 1218) - каракитайская ханша, жена Кучлук хана (1206 - 1218). Была дочерью гурхана Елюй Чжулхуя. Выдано замуж за найманского хана Кучлуку. Была советницой и любимой женой Кучлук хана при его правлении."
    },
    "ru": {
      "language": "ru",
      "value": "дочь императора Чжулху"
    }
  },

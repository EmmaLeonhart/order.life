  "descriptions": {
    "ja": {
      "language": "ja",
      "value": "戦国時代から江戸時代初期の武将。宇喜多氏の家臣、江戸幕府 旗本寄合席5000石。備中高松城主、備中猿掛領の初代領主。従五位下、志摩守。子に花房順一（検校）、楢村孫兵衛の妻、大島義治の妻、前田正信の妻"
    },
    "nl": {
      "language": "nl",
      "value": "commandant"
    }

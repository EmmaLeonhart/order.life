  "descriptions": {
    "de": {
      "language": "de",
      "value": "Nach Cicero ist der dritte Asklepios, der »messenischen Asklepios«, der Sohn von Arsippos und Arsinoe; vgl. Kleine Pauly, Bd. II, Sp. 37."
    },
    "en": {
      "language": "en",
      "value": "father of one of Cicero's three Aesculapii"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque, père d'Asclépios"
    },
    "nl": {
      "language": "nl",
      "value": "figuur uit de Griekse mythologie"
    },
    "ru": {
      "language": "ru",
      "value": "персонаж древнегреческой мифологии"
    },
    "sl": {
      "language": "sl",
      "value": "oseba v grški mitologiji; z Arsinojo oče mesenskega Asklepija"
    }

  "descriptions": {
    "el": {
      "language": "el",
      "value": "Ικανότητα του ανθρώπου να διατηρεί σταθερό το εσωτερικό του περιβάλλον, παρά τις εξωτερικές μεταβολές, απαραίτητη για την επιβίωση."
    },
    "en": {
      "language": "en",
      "value": "the state of steady internal conditions maintained by living things"
    },

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "اول ملوك ثيفا ومكتشفها،قاطع رأس ميدوسا وبيليروفون قاتل كمير"
    },
    "ca": {
      "language": "ca",
      "value": "Segons la mitologia grega, fill del rei Agenor, i fundador de la ciutat de Tebes a Beòcia"
    },
    "da": {
      "language": "da",
      "value": "prins i græsk mytologi"
    },
    "de": {
      "language": "de",
      "value": "König der griechischen Mythologie"
    },
    "el": {
      "language": "el",
      "value": "πρόσωπο της αρχαίας ελληνικής μυθολογίας"
    },
    "en": {
      "language": "en",
      "value": "mythological founder of Thebes, son of Agenor"
    },
    "es": {
      "language": "es",
      "value": "personaje de la mitología griega, fundador de Tebas"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque"
    },
    "gv": {
      "language": "gv",
      "value": "bunneyder feayn-skeealleydagh Thebes, mac lesh Agenor"
    },
    "he": {
      "language": "he",
      "value": "דמות פיניקית במיתולוגיה היוונית, מייסד תבאי ובן אגנור מלך צור"
    },
    "hu": {
      "language": "hu",
      "value": "görög mitológiai alak, Agénór és Télephassza fia"
    },
    "it": {
      "language": "it",
      "value": "personaggio della mitologia greca"
    },
    "ja": {
      "language": "ja",
      "value": "ギリシア神話に登場する人物"
    },
    "ko": {
      "language": "ko",
      "value": "그리스 신화의 등장인물로, 아게노르의 아들"
    },
    "ku": {
      "language": "ku",
      "value": "Pismîrê Fenîkeyê yên efsaneyî"
    },
    "nl": {
      "language": "nl",
      "value": "figuur uit de Griekse mythologie"
    },
    "pl": {
      "language": "pl",
      "value": "postać z mitologii greckiej"
    },
    "pt": {
      "language": "pt",
      "value": "personagem da mitologia grega"
    },
    "ro": {
      "language": "ro",
      "value": "rege din mitologia greacă"
    },
    "ru": {
      "language": "ru",
      "value": "персонаж древнегреческой мифологии, сын Агенора, основатель Фив"
    },
    "sl": {
      "language": "sl",
      "value": "mitološki ustanovitelj Teb, Agenorjev sin"
    },
    "sq": {
      "language": "sq",
      "value": "Hero i mitologjise greke me origjine fenikase"
    },
    "sv": {
      "language": "sv",
      "value": "staden Thebes grundare, bror till Europa, stamfar till Oidipus i grekisk mytologi"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisi karakteri, Thebai'nin kurucusu"
    },
    "vi": {
      "language": "vi",
      "value": "người sáng lập thành Thebes, con trai của vua Agenor trong thần thoại Hy Lạp"
    }
  },

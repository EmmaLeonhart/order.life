      "value": "عمه علي بن أبي طالب وهو سفير الحسين بن علي إلى الكوفة"
    },
    "ca": {
      "language": "ca",
      "value": "nebot de Hussayn ibn Alí mort l'any 680"
    },
    "en": {
      "language": "en",
      "value": "Son of Aqil ibn Abi Talib and cousin of Husain ibn Ali (died 680)"
    },
    "es": {
      "language": "es",
      "value": "sobrino de Husáin ibn Ali, fallecido en el 680"
    },

  "descriptions": {
    "ja": {
      "language": "ja",
      "value": "平安時代後期から鎌倉時代初期の公卿。藤原公通の長男。正二位内大臣。出家。西園寺家3代。子に藤原公仲、公暁（延暦寺、西塔院主、妙上房法印）-公澄（延暦寺、法印権大僧都、西塔院主、北野別当、曼殊院）"
    },
    "pt": {
      "language": "pt",
      "value": "Kuge do Período Heian da história do Japão"
    }
  },

  "descriptions": {
    "be": {
      "language": "be",
      "value": "міфалогія"
    },
    "ca": {
      "language": "ca",
      "value": "divinitat grega, déu dels pastors i els ramats"
    },
    "cs": {
      "language": "cs",
      "value": "řecký bůh"
    },
    "da": {
      "language": "da",
      "value": "hyrdens og dyreflokkens gud i græsk mytologi"
    },
    "de": {
      "language": "de",
      "value": "griechische Gottheit der Hirten"
    },
    "el": {
      "language": "el",
      "value": "θεότητα της ελληνικής μυθολογίας"
    },
    "en": {
      "language": "en",
      "value": "Greek god of the mountain wilds, shepherds, flocks, rustic music, fertility, spring, and theatrical criticism, with the hindquarters, legs, and horns of a goat"
    },
    "eo": {
      "language": "eo",
      "value": "helena dio de montoj, paŝtado, fekundeco, kaj kampara muziko, kies aspekto similas satiruson, kun kapraj kruroj kaj kornoj"
    },
    "es": {
      "language": "es",
      "value": "dios griego de los rebaños y pastores"
    },
    "fi": {
      "language": "fi",
      "value": "kreikkalaisen mytologian jumala"
    },
    "fr": {
      "language": "fr",
      "value": "divinité de la mythologie grecque de la nature, protecteur des bergers et des troupeaux, souvent représenté comme une créature chimérique, mi-homme mi-bouc"
    },
    "gl": {
      "language": "gl",
      "value": "deus dos pastores e dos rabaños na mitoloxía grega"
    },
    "he": {
      "language": "he",
      "value": "אל יווני"
    },
    "hr": {
      "language": "hr",
      "value": "grčki bog pastira, stada, šuma, njiva i polja"
    },
    "ig": {
      "language": "ig",
      "value": "Chi ndị Gris nke ọhịa ọhịa, ndị ọzụzụ atụrụ, ìgwè ewu na atụrụ, egwú ndị na-adịghị mma, ịmụ nwa, oge opupu ihe ubi, na ihe nkiri, nke nwere azụ azụ, ụkwụ, na mpi ewu."
    },
    "it": {
      "language": "it",
      "value": "divinità greca delle selve, della pastorizia e della fertilità"
    },
    "ja": {
      "language": "ja",
      "value": "ギリシア神話の神"
    },
    "ko": {
      "language": "ko",
      "value": "염소의 하반신과 뿔을 가진 그리스 신화의 산과 야생, 양치기, 양떼, 시골 음악, 다산, 봄, 연극 비평의 신"
    },
    "nb": {
      "language": "nb",
      "value": "gud assosiert med skog og begjær i gresk mytologi"
    },
    "nl": {
      "language": "nl",
      "value": "figuur uit de Griekse mythologie"
    },
    "pt": {
      "language": "pt",
      "value": "deus grego dos bosques e do pasto"
    },
    "pt-br": {
      "language": "pt-br",
      "value": "de acordo com a mitologia grega, o deus grego dos lugares selvagens das montanhas, dos pastores, dos rebanhos, da música campestre, da fertilidade, da primavera e da crítica teatral é representado com a parte traseira, pernas e chifres de uma cabra"
    },
    "ro": {
      "language": "ro",
      "value": "zeul sălbăticiei și păstoritului în mitologia greacă"
    },
    "ru": {
      "language": "ru",
      "value": "древнегреческий бог"
    },
    "scn": {
      "language": "scn",
      "value": "diu dâ campagna ntâ mituluggìa greca"
    },
    "sl": {
      "language": "sl",
      "value": "grški bog gorske divjine, pastirjev, čred, kmečke glasbe, plodnosti, pomladi in gledališke kritike; z zadnjico, nogami in rogovi kozla"
    },
    "sv": {
      "language": "sv",
      "value": "halvgud inom grekisk mytologi"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisinde hayvan biçimli doğa tanrısı"
    },
    "zh": {
      "language": "zh",
      "value": "希腊神话中的牧神"
    },
    "zh-hk": {
      "language": "zh-hk",
      "value": "希臘神話中的牧神"
    },
    "zh-tw": {
      "language": "zh-tw",
      "value": "希臘神話中的牧神"
    }
  },

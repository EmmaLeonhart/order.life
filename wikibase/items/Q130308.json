  "descriptions": {
    "am": {
      "language": "am",
      "value": "መጽሐፍ ቅዱሳዊ ምስል"
    },
    "ar": {
      "language": "ar",
      "value": "ريفاث هو ريفاث بن غومر بن يافث بن نوح، الشقيق الأصغر لأشكناز، والأخ الأكبر لتوجرمة وفقًا لجدول الأمم في الكتاب المقدس العبري سفر التكوين 10: 3. يظهر الاسم في بعض نسخ سفر أخبار الأيام الأول كـ «ديفاث»، نظرًا للتشابه بين الأحرف ר وד في الأبجدية العبرية"
    },
    "ba": {
      "language": "ba",
      "value": "Гомерҙың улы, Фогарм менән Аскеназдың бер туғаны"
    },
    "de": {
      "language": "de",
      "value": "biblische Figur, zweitältester Sohn Gomers"
    },

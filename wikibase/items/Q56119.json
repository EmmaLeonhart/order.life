  "descriptions": {
    "be": {
      "language": "be",
      "value": "(XIV ст.) княжна валынская, жонка Любарта Гедзімінавіча"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "(XIV ст.) княжна валынская, жонка Любарта Гедзімінавіча"
    },
    "uk": {
      "language": "uk",
      "value": "руська княгиня з династії Романовичів, донька останнього князя з династії та дружина литовського князя Любарта Гедиміновича, шлюб з якою дозволив останньому претендувати на спадщину Королівства Русі"
    }

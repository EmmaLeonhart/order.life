  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "سبط النبي محمد صلى الله عليه وسلم ، ابن رقية بنت محمد زوجة أمير المؤمنين ثالث الخلفاء الراشدين ذي النورين عثمان بن عفان"
    },
    "ca": {
      "language": "ca",
      "value": "sahabí (company de Muhàmmad)"
    },
    "en": {
      "language": "en",
      "value": "son of the third caliph Uthman"
    },
    "es": {
      "language": "es",
      "value": "hijo del tercer califa Uthman"
    },
    "fa": {
      "language": "fa",
      "value": "نوه پیامبر اسلام محمد"
    },
    "ur": {
      "language": "ur",
      "value": "عثمان عنہ اور سیدہ رقیہ بنت محمد کے صاحبزادے جو چھ سال کی عمر میں فوت ہوئے۔"
    },
    "uz": {
      "language": "uz",
      "value": "Abdulloh ibn Usmon ibn Affon Muhammad paygʻambarning nabiralari"
    }
  },

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "ساموراي ياباني"
    },
    "ast": {
      "language": "ast",
      "value": "samurái xaponés (1576–1655)"
    },
    "de": {
      "language": "de",
      "value": "japanischer Samurai"
    },
    "en": {
      "language": "en",
      "value": "Daimo who was vice-commander of the shogunate forces during the Shimabara Rebellion"
    },
    "ja": {
      "language": "ja",
      "value": "安土桃山時代から江戸時代前期の武将、大名。徳川氏の家臣。近江膳所藩2代藩主、摂津尼崎藩主、美濃大垣藩初代藩主。大垣藩戸田家2代。戸田一西の長男。従五位下、采女正、従四位下、贈従三位。子に頓誉上人（三男）、戸田氏頼（四男、五郎左衛門、母は蒲生氏（側室））"
    },
    "nl": {
      "language": "nl",
      "value": "Japans Samoerai (-1655)"
    },
    "tr": {
      "language": "tr",
      "value": "Japon derebeyi/daimyō (1576 – 1655)"
    }
  },

      "language": "nl",
      "value": "Grieks mythologisch figuur, zoon van Niobe en Zeus"
    },
    "ru": {
      "language": "ru",
      "value": "персонаж древнегреческой мифологии, сын Зевса и Ниобы, эпоним города Аргос"
    },
    "sl": {
      "language": "sl",
      "value": "kralj in eponim Arga v grški mitologiji; Zevsov sin"
    },

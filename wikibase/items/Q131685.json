      "value": "König der griechischen Mythologie"
    },
    "en": {
      "language": "en",
      "value": "mythological Greek character, king and eponym of Argos"
    },
    "es": {
      "language": "es",
      "value": "personaje de la mitología griega, hijo de Zeus"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque, fils de Zeus, roi d'Argos"
    },
    "he": {
      "language": "he",
      "value": "בנו של זאוס ומלך ארגוס במיתולוגיה היוונית"
    },
    "hu": {
      "language": "hu",
      "value": "görög mitológiai alak, Zeusz fia, Argosz királya"
    },
    "it": {
      "language": "it",
      "value": "re ed eponimo di Argo nella mitologia greca, figlio di Zeus"
    },

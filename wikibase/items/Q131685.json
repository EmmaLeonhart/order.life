  "descriptions": {
    "be": {
      "language": "be",
      "value": "персанаж старажытнагрэчаскай міфалогіі, сын Зеўса і Ніёбы, эпанім горада Аргас"
    },
    "ca": {
      "language": "ca",
      "value": "fill de Zeus"
    },

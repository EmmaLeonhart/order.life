  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "إله الخمر في الميثولوجيا الإغريقية"
    },
    "ca": {
      "language": "ca",
      "value": "En la mitologia grega déu del vi, el teatre o la rauxa"
    },
    "cs": {
      "language": "cs",
      "value": "řecký bůh vína"
    },
    "da": {
      "language": "da",
      "value": "vinens og ekstasens gud i græsk mytologi"
    },
    "de": {
      "language": "de",
      "value": "griechische Gottheit des Weins und der Fruchtbarkeit"
    },
    "en": {
      "language": "en",
      "value": "ancient Greek god of winemaking and wine"
    },
    "eo": {
      "language": "eo",
      "value": "helena dio de vino kaj vinfarado"
    },
    "es": {
      "language": "es",
      "value": "antiguo dios griego de la vinificación y del vino"
    },
    "fi": {
      "language": "fi",
      "value": "antiikin kreikkalainen jumala"
    },
    "fr": {
      "language": "fr",
      "value": "dieu grec antique de la vigne, de la fête, de la folie et du théâtre"
    },
    "gl": {
      "language": "gl",
      "value": "deus do viño e da vendima na mitoloxía grega"
    },
    "he": {
      "language": "he",
      "value": "אל אולימפי"
    },
    "hu": {
      "language": "hu",
      "value": "ókori görög isten"
    },
    "id": {
      "language": "id",
      "value": "Dewa pesta, anggur, teater, mabuk, dan kegembiraan mitologi Yunani"
    },
    "it": {
      "language": "it",
      "value": "dio greco del vino, della vendemmia, dei teatri, della fertilità e dell'ubriachezza"
    },
    "ja": {
      "language": "ja",
      "value": "ギリシア神話に登場する豊穣とブドウ酒と酩酊の神"
    },
    "ko": {
      "language": "ko",
      "value": "그리스 신화의 포도주와 양조의 신"
    },
    "lb": {
      "language": "lb",
      "value": "griichesch Naturgottheet"
    },
    "nl": {
      "language": "nl",
      "value": "mythologische figuur"
    },
    "pl": {
      "language": "pl",
      "value": "bóg dzikiej natury, winnej latorośli, wina (mitologia grecka)"
    },
    "ps": {
      "language": "ps",
      "value": "د لرغوني يونان د شرابو او شراب جوړونې خدای"
    },
    "pt": {
      "language": "pt",
      "value": "deus grego do vinho e da vinicultura"
    },
    "pt-br": {
      "language": "pt-br",
      "value": "deus grego do vinho e da vinicultura"
    },
    "ro": {
      "language": "ro",
      "value": "zeul vinului, extazului și fertilității în mitologia greacă"
    },
    "ru": {
      "language": "ru",
      "value": "древнегреческий бог растительности, виноградарства, виноделия, производительных сил природы, вдохновения, религиозного экстаза и театра."
    },
    "sl": {
      "language": "sl",
      "value": "starogrški bog vinske trte, festivalov, norosti in gledališča"
    },
    "sv": {
      "language": "sv",
      "value": "en av olympierna inom grekisk mytologi"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisinde coşkunluk, sarhoşluk ve şarap tanrısı"
    },
    "vi": {
      "language": "vi",
      "value": "Thần rượu nho"
    },
    "zh": {
      "language": "zh",
      "value": "古希腊神祇"
    }

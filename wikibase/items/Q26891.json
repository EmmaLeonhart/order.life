  "descriptions": {
    "cs": {
      "language": "cs",
      "value": "čínský aristokrat, syn a následník trůnu mingského císaře Chung-wua"
    },
    "en": {
      "language": "en",
      "value": "Ming Dynasty prince"
    },
    "ja": {
      "language": "ja",
      "value": "朱元璋の長男。皇太子。"
    },
    "ko": {
      "language": "ko",
      "value": "홍무제의 황자"
    },
    "lzh": {
      "language": "lzh",
      "value": "明懿文太子標，朱氏，諱標，太祖嫡長子也，生母孝慈高皇后馬氏。未即皇位，諡曰懿文太子。葬於南京明孝陵東側。"
    },
    "nl": {
      "language": "nl",
      "value": "aristocraat uit China (1355-1392)"
    },
    "vi": {
      "language": "vi",
      "value": "Thái tử nhà Minh, con trai Minh Thái Tổ"
    },
    "zh": {

  "descriptions": {
    "ca": {
      "language": "ca",
      "value": "noble de cort a finals del període Heian. El fill gran de Fujiwarano Mototaka. Jusanmi, no de cara. Un vassall proper de Tobain. Un genet a cavall"
    },
    "en": {
      "language": "en",
      "value": "court noble in the late Heian period. The eldest son of FUJIWARA no Mototaka. Jusanmi, non-countenant. A close vassal of Tobain. A horse riding rider"
    },
    "ja": {
      "language": "ja",
      "value": "平安時代後期の公卿。藤原基隆の長男。従三位・非参議。鳥羽院近臣。乗馬の達人"
    }
  },

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "زوجة الخليفة العباسي المهدي ووالدة الخليفتين الهادي والرشيد"
    },
    "ca": {
      "language": "ca",
      "value": "esposa del califa abbàssida al-Mahdí"
    },
    "en": {
      "language": "en",
      "value": "Wife of the Abbasid Caliph Al-Mahdi and de facto ruler of the Abbasid Caliphate from 775 to 789"
    },
    "eu": {
      "language": "eu",
      "value": "Al-Mahdi kalifa abbastarraren emaztea eta 775etik 789ra abbastarren kaliferriko de facto gobernaria"
    },
    "fa": {
      "language": "fa",
      "value": "اولین ملکه مقتدر تاریخ اسلام"
    },
    "fr": {
      "language": "fr",
      "value": "femme politique abbasside, épouse du calife Al-Mahdi"
    },
    "nl": {
      "language": "nl",
      "value": "schrijfster (????-0789)"
    },
    "pl": {
      "language": "pl",
      "value": "żona kalifa Al-Mahdiego i matka kalifów Al-Hadiego i Haruna ar-Raszida"
    },
    "ur": {
      "language": "ur",
      "value": "خلافت عباسیہ کی پہلی نامور شہرت یافتہ ملکہ جو خلیفہ المہدی باللہ کی زوجہ اور خلیفہ ابوموسیٰ الہادی اور ہارون الرشید کی والدہ تھیں۔"
    }
  },

      "value": "naiade, moglie di Egitto"
    },
    "ru": {
      "language": "ru",
      "value": "нимфа из древнегреческой мифологии"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisinde göl kaynak ve diğer sulak doğa unsurlarını kişileştiren tanrıça (naiades)"
    }

    },
    "he": {
      "language": "he",
      "value": "נאיאדה אשתו של אייגיפטוס במיתולוגיה היוונית"
    },
    "hu": {
      "language": "hu",
      "value": "görög mitológiai alak, Aigüptosz felesége"
    },

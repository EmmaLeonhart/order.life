  "descriptions": {
    "ca": {
      "language": "ca",
      "value": "en la mitologia grega, princesa argòlida, filla del rei Acrisi i d'Eurídice, filla de Lacedèmon, rei d'Esparta"
    },
    "cs": {
      "language": "cs",
      "value": "postava v řecké mytologii"
    },
    "cy": {
      "language": "cy",
      "value": "merch Acrisius o Argos a'r Frenhines Eurydice, mam Perseus, ym mytholeg Roeg"
    },
    "de": {
      "language": "de",
      "value": "Person der griechischen Mythologie"
    },
    "en": {
      "language": "en",
      "value": "daughter of Acrisius of Argos and Queen Eurydice, mother of Perseus, in Greek mythology"
    },
    "es": {
      "language": "es",
      "value": "personaje del mito griego"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque, fille d'Acrisios et d'Eurydice, mère de Persée"
    },
    "he": {
      "language": "he",
      "value": "נסיכה מהעיר ארגוס ואמו של הגיבור פרסאוס"
    },
    "hu": {
      "language": "hu",
      "value": "görög mitológiai alak, Akrisziosz lánya"
    },
    "it": {
      "language": "it",
      "value": "personaggio della mitologia greca, figlia di Acrisio e madre di Perseo"
    },
    "ja": {

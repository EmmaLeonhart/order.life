  "descriptions": {
    "be": {
      "language": "be",
      "value": "Эсак — персанаж старажытнагрэчаскай міфалогіі"
    },
    "ca": {
      "language": "ca",
      "value": "heroi fill del rei de Troia Príam, les seves aventures succeïren abans de l'inici de la Guerra de Troia"
    },
    "cs": {
      "language": "cs",
      "value": "v řecké mytologii synem trojského krále Priama a jeho první manželky Arisbé"
    },
    "de": {
      "language": "de",
      "value": "Figur der griechischen Mythologie, Sohn des Priamos"
    },
    "el": {
      "language": "el",
      "value": "γιος του βασιλιά της Τροίας Πριάμου από την πρώτη του γυναίκα, την Αρίσβη, κόρη του Μέροπα (Απολλόδ"
    },
    "en": {
      "language": "en",
      "value": "son of Priam in Greek mythology"
    },
    "eo": {
      "language": "eo",
      "value": "Esako (helene Αίσακος, latine Aesacus) estis en la helena mitologio filo de troja reĝo Priamo kaj de lia unua edzino Arisba"
    },
    "es": {
      "language": "es",
      "value": "Ésaco es en la mitología griega un hijo de Príamo y Arisbe"
    },
    "fr": {
      "language": "fr",
      "value": "personnage de la mythologie grecque, fils de Priam"
    },
    "hu": {
      "language": "hu",
      "value": "görög mitológiai alak, Priamosz és Ariszbé fia"
    },
    "id": {
      "language": "id",
      "value": "putra raja Priam dari Troya"
    },
    "it": {
      "language": "it",
      "value": "personaggio della mitologia greca, figlio di Priamo re di Troia e Arisbe, sua prima moglie"
    },
    "ja": {
      "language": "ja",
      "value": "、ギリシア神話の人物である"
    },
    "lt": {
      "language": "lt",
      "value": "Trojos karaliaus Priamo ir Arisbės sūnus"
    },
    "nl": {
      "language": "nl",
      "value": "zoon van koning Priamus van Troje en de nimf Arisbe van de rivier de Granicus"
    },
    "pl": {
      "language": "pl",
      "value": "postać z mitologii greckiej"
    },
    "pt": {
      "language": "pt",
      "value": "Na mitologia grega, Esaco é filho de Príamo e de sua primeira esposa Arisbe, filha de Merops"
    },
    "ru": {
      "language": "ru",
      "value": "персонаж древнегреческой мифологии, сын Приама и Арисбы"
    },
    "sk": {
      "language": "sk",
      "value": "v gréckej mytológii syn trójskeho kráľa Priama a jeho prvej manželky Arisby"
    },
    "sr": {
      "language": "sr",
      "value": "у грчкој митологији био пророк"
    },
    "sv": {
      "language": "sv",
      "value": "prins i grekisk mytologi"
    },
    "tr": {
      "language": "tr",
      "value": "Yunan mitolojisinde son Truva kralı Priamos'ın oğlu"
    },
    "uk": {
      "language": "uk",
      "value": "персонаж давньогрецької міфології"
    }
  },

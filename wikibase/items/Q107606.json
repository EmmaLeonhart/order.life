  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "حَبر الأمة، وترجمان القرءان، صحابي محدث وفقيه وحافظ ومُفسِّر، وابن عم الرسول محمد، وأحد المكثرين لرواية الحديث"
    },
    "arz": {
      "language": "arz",
      "value": "مؤرخ من الخلافه الراشده"
    },
    "az": {
      "language": "az",
      "value": "Məhəmməd peyğəmbərin tanınmış səhabəsi, İslam alimi və fəqihi"
    },
    "bn": {
      "language": "bn",
      "value": "বিশিষ্ট সাহাবী। রইসূল মুফাসসিরীন।"
    },
    "ca": {
      "language": "ca",
      "value": "sahabí (company del profeta Muhàmmad), mufàssir (exegeta de l'Alcorà) i membre de la família abbàssida"

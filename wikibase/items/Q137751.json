      "language": "bn",
      "value": "যিশুর মাতা মেরীর স্বামী"
    },
    "ca": {
      "language": "ca",
      "value": "sant catòlic, espós de Maria i pare de Jesús"
    },
    "cs": {
      "language": "cs",
      "value": "manžel Panny Marie, která porodila Ježíše Krista"

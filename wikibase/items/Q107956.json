  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "بنت الصحابي طلحة بن عبيد الله، وزوجة الحسن والحسين (بن علي بن أبي طالب)"
    },
    "bn": {
      "language": "bn",
      "value": "তালহা ইবনে উবাইদুল্লাহর কন্যা এবং হাসান ইবনে আলীর স্ত্রী"
    },
    "ca": {
      "language": "ca",
      "value": "filla de Talha ibn Ubayd-Al·lah, esposa d'al-Hàssan i al-Hussayn, fills de l'imam Alí"
    },
    "en": {
      "language": "en",
      "value": "Daughter of Talhah and wife of Hasan and Husayn"
    },
    "fa": {
      "language": "fa",
      "value": "از همسران حسن و حسین بن علی"
    },
    "ru": {
      "language": "ru",
      "value": "жена Хусейна"
    }

  "descriptions": {
    "acm": {
      "language": "acm",
      "value": "حفيد محمد وابن علي ابن ابي طالب وفاطمة الزهراء، وثالث الائمة عند الشيعة"
    },
    "ar": {
      "language": "ar",
      "value": "سبط محمد وابن علي بن أبي طالب وفاطمة الزهراء، وثالث الائمة عند الشيعة"
    },
    "arz": {
      "language": "arz",
      "value": "سبط محمد"
    },
    "as": {
      "language": "as",
      "value": "হজৰত মুহাম্মদৰ নাতিনী তৃতীয় ইমাম (৬২৬-৬৮০)"
    },
    "az": {
      "language": "az",
      "value": "Məhəmmədin nəvəsi və Əli ibn Əbu Talibin oğlu, 3-cü imam"
    },
    "bn": {
      "language": "bn",
      "value": "মুহাম্মদের নাতি ও তৃতীয় ইমাম"
    },
    "ca": {
      "language": "ca",
      "value": "fill de l'imam Alí, imam xiïta i sahabí (company del profeta Muhàmmad)"
    },
    "ce": {
      "language": "ce",
      "value": "Мухьаммадан йоӀан кӀант, Ӏалий ибн Абу ТӀалибан а, ФатӀиматан а кӀант, шиӀашна гергахь кхоалгӀа имам"
    },
    "ckb": {

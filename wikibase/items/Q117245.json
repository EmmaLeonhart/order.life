  "descriptions": {
    "bg": {
      "language": "bg",
      "value": "граф на графството Яфа и Аскалон в Йерусалимското кралство"
    },
    "ca": {
      "language": "ca",
      "value": "noble croat comte de Jaffa i d'Ascaló del 1176 a 1177, fill de Guillem V de Montferrat, marquès de Montferrat i de Judit de Babenberg"
    },
    "de": {
      "language": "de",
      "value": "Graf von Jaffa und Askalon"
    },
    "el": {
      "language": "el",
      "value": "μεγαλύτερος γιος του Γουλιέλμου Ε΄ του Μομφερράτου και της Ιουδήθ του Μπάμπενμπερκ"
    },
    "en": {
      "language": "en",
      "value": "the Count of Jaffa and Ascalon, the eldest son of William V, Marquess of Montferrat and Judith of Babenberg"
    },
    "es": {
      "language": "es",
      "value": "el Conde de Jaffa y Ascalón"
    },
    "fr": {
      "language": "fr",
      "value": "comte de Jaffa et d'Ascalon"
    },
    "nl": {
      "language": "nl",
      "value": "de oudste zoon van Willem V van Monferrato en Judith van Babenberg"
    },
    "pt": {
      "language": "pt",
      "value": "conde de Jafa e Ascalão jure uxoris de 1176 até à sua morte, pelo seu casamento com Sibila de Jerusalém"
    },
    "ru": {
      "language": "ru",
      "value": "граф Яффы и Аскалона"
    }

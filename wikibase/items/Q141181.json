  "descriptions": {
    "de": {
      "language": "de",
      "value": "Alte russische Prinzessin; Tochter des Nowgoroder Plantagenarbeiters Petrila Mikulchich; Frau des Fürsten Swjatoslaw Olgowitsch und Mutter des Fürsten Igor Swjatoslawitsch;"
    },
    "en": {
      "language": "en",
      "value": "ancient Russian princess; daughter of Novgorod plantation worker Petrila Mikulchich; wife of Prince Svyatoslav Olgovich and mother of Prince Igor Svyatoslavovich;- Apr 1164"
    },
    "fr": {
      "language": "fr",
      "value": "ancienne princesse russe ; fille de Petrila Mikulchich, ouvrière de plantation à Novgorod ; épouse du prince Svyatoslav Olgovitch et mère du prince Igor Svyatoslavovitch"
    },
    "ru": {
      "language": "ru",
      "value": "древнерусская княгиня; дочь новгородского посадника Петрилы Микульчича; жена князя Святослава Ольговича и мать князя Игоря Святославовича;"
    }
  },

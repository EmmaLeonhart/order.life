  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "الله الابن هو الأقنوم الثاني من الثالوث في اللاهوت المسيحي"
    },
    "be-tarask": {
      "language": "be-tarask",
      "value": "Ісус Хрыстос у Сьвятой Тройцы"
    },
    "cs": {
      "language": "cs",
      "value": "Ježíš v kontextu Nejsvětější Trojice"
    },
    "el": {
      "language": "el",
      "value": "στον Χριστιανισμό, το δεύτερο πρόσωπο της Αγίας Τριάδας, που γεννήθηκε από τον Θεό Πατέρα και ενσαρκώθηκε ως Ιησούς Χριστός"
    },
    "en": {
      "language": "en",
      "value": "in Christianity, the second person of the Trinity, begotten by God the Father, incarnated as Jesus Christ"
    },
    "eo": {
      "language": "eo",
      "value": "je Kristanismo, la dua persono de la Triunuo, enkarniĝinta kiel Jesuo Kristo"
    },
    "es": {
      "language": "es",
      "value": "segunda persona de la Santísima Trinidad"
    },
    "he": {
      "language": "he",
      "value": "אחד משלושת פניו של השילוש הקדוש בנצרות"
    },
    "hu": {
      "language": "hu",
      "value": "a keresztény szentháromság-doktrína fogalma"
    },
    "id": {
      "language": "id",
      "value": "tradisi kekristenan; identik dengan konsep tritunggal (Bapa, Putra, Roh Kudus) dan Allah Anak atau Allah Putra merupakan konsep tritunggal kedua"
    },
    "it": {
      "language": "it",
      "value": "nella teologia cristiana, seconda delle tre Persone della Trinità"
    },
    "ja": {
      "language": "ja",
      "value": "三位一体の第二位格"
    },
    "ko": {
      "language": "ko",
      "value": "삼위일체의 제2위"
    },
    "nn": {
      "language": "nn",
      "value": "den andre personen i den kristne treeininga, Jesus"
    },
    "pl": {
      "language": "pl",
      "value": "w chrześcijaństwie, druga osoba Trójcy Świętej, znana jako Jezus Chrystus"
    },
    "pt": {
      "language": "pt",
      "value": "segunda pessoa da Trindade, gerada por Deus Pai, encarnada como Jesus Cristo"
    },
    "pt-br": {
      "language": "pt-br",
      "value": "segunda pessoa da Trindade, gerada por Deus Pai, encarnada como Jesus Cristo"
    },
    "ru": {
      "language": "ru",
      "value": "часть христианской Троицы"
    },
    "sl": {
      "language": "sl",
      "value": "v krščanstvu druga oseba Trojice, ki se je utelesila kot Jezus Kristus"
    },
    "sr": {
      "language": "sr",
      "value": "друго лице Свете Тројице"
    },
    "sv": {
      "language": "sv",
      "value": "begrepp för Jesus inom kristen treenighetslära"
    },
    "tl": {
      "language": "tl",
      "value": "Ikalawang persona ng Santatlo sa teolohiyang Kristiyano"
    },
    "tr": {
      "language": "tr",
      "value": "Hıristiyanlıkta, Üçlü Birliğin ikinci kişisi, Baba Tanrı tarafından yaratılmış, İsa Mesih olarak beden almış"
    },
    "zh": {
      "language": "zh",
      "value": "在基督教神學中，為三位一體教義中的第二個位格，即「上帝的獨生子耶穌」"

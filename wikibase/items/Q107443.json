  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "محدث وفقيه وصحابي، ابن الخليفة عمر بن الخطاب، وأحد المكثرين في الفتوى ورواية الحديث"
    },
    "az": {
      "language": "az",
      "value": "Məhəmməd peyğəmbərin səhabəsi"
    },
    "ca": {
      "language": "ca",
      "value": "sahabí (company del profeta Muhàmmad), muhàddith (transmissor i/o estudiós dels hadits) i mufàssir (exegeta de l'Alcorà)"
    },
    "ce": {
      "language": "ce",
      "value": "мухьаддис, факъихӀ, Мухьаммад пайхамаран асхьабех цхьаъ"

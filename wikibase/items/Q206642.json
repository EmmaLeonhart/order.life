  "descriptions": {
    "be": {
      "language": "be",
      "value": "кароль Заходне-Франкскага каралеўства (840—877)"
    },
    "bs": {
      "language": "bs",
      "value": "car Svetog Rimskog Carstva"
    },
    "ca": {
      "language": "ca",
      "value": "rei de França Occidental i Emperador Carolingi"
    },
    "cs": {
      "language": "cs",
      "value": "západofranský král"
    },
    "cy": {
      "language": "cy",
      "value": "Ymerawdwr Glân Rhufeinig o 875 hyd 877"
    },
    "de": {
      "language": "de",
      "value": "westfränkischer König (843–877) und Kaiser (875–877)"
    },
    "en": {
      "language": "en",
      "value": "King of West Francia from 843 to 877 and Carolingian Emperor from 875 to 877"
    },
    "eo": {
      "language": "eo",
      "value": "okcidentfranka reĝo kaj imperiestro"
    },
    "es": {
      "language": "es",
      "value": "Rey de Francia Occidental (843-877) y Emperador Carolingio (875-877)."
    },
    "fi": {
      "language": "fi",
      "value": "frankkilais-roomalainen kuningas ja keisari."
    },
    "fr": {
      "language": "fr",
      "value": "roi d'Aquitaine, puis roi de Francie, puis empereur d'Occident"
    },
    "gl": {
      "language": "gl",
      "value": "reio dos francos de 843 a 877 e emperador do Sacro Imperio Romano de 875 a 877"
    },
    "he": {
      "language": "he",
      "value": "מלך פרנקיה המערבית"
    },
    "hr": {
      "language": "hr",
      "value": "kralja Zapadne Franačke"
    },

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "الزوجة الثانية لشارلمان، احدى أبناء ديسيديريوس ملك لومبارديا، ملكة الفرنجة القرينة"
    },
    "br": {
      "language": "br",
      "value": "merc'h da z-Dider Lombardia"
    },
    "cs": {
      "language": "cs",
      "value": "druhá manželka Karla Velikého, jedna ze čtyř dcer Desideria, krále Langobardů"
    },
    "de": {
      "language": "de",
      "value": "zweite Ehefrau Frau Karls des Großen"
    },
    "en": {
      "language": "en",
      "value": "second wife of Charlemagne, one of four daughters of Desiderius, king of the Lombards"
    },
    "es": {
      "language": "es",
      "value": "segunda mujer de Carlomagno"
    },
    "fr": {
      "language": "fr",
      "value": "princesse lombarde, fille du roi Didier et première épouse officielle de Charlemagne"
    },
    "he": {
      "language": "he",
      "value": "אשתו של קרל הגדול ובתו של דזידריוס מלך הלומברדים"
    },
    "it": {
      "language": "it",
      "value": "principessa longobarda figlia di re Desiderio"
    },
    "ko": {
      "language": "ko",
      "value": "솔직한 여왕의 배우자"
    },
    "nl": {
      "language": "nl",
      "value": "dochter van Desiderius van Lombardije en van Ansa, tweede echtgenote van Karel de Grote"
    },
    "ro": {
      "language": "ro",
      "value": "a doua soție a lui Carol cel Mare"
    },
    "ru": {
      "language": "ru",
      "value": "дочь лонгобардского короля Дезидерия, вторая жена Карла Великого"
    }
  },

  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "ابنة الإمبراطور البيزنطي موريقيوس وزوجة الشاه كسرى الثاني"
    },
    "be": {
      "language": "be",
      "value": "дачка візантыйскага імператара Маўрыкія"
    },
    "el": {
      "language": "el",
      "value": "κόρη του βυζαντινού αυτοκράτορα Μαυρικίου"
    },
    "en": {
      "language": "en",
      "value": "daughter of Byzantine emperor Maurice, and wife of Khosrau II"
    },
    "es": {
      "language": "es",
      "value": "hija del emperador bizantino Mauricio y esposa del emperador sasánida Cosroes II"
    },
    "he": {
      "language": "he",
      "value": "בתו של הקיסר הביזנטי מאוריקיוס ואשתו של המלך הסאסאני ח'וסרו השני"
    },
    "ru": {
      "language": "ru",
      "value": "дочь византийского императора Маврикия"
    },
    "tr": {
      "language": "tr",
      "value": "Mauricius'un kızı, II. Hüsrev'in karısı"
    },
    "uk": {
      "language": "uk",
      "value": "дружина Хозрова II"
    },
    "ur": {
      "language": "ur",
      "value": "بازنطینی شہنشاہ موریس کی بیٹی، کسریٰ فارس خسرو پرویز کی بیوی اور ملکہ فارس بوران دخت کی والدہ۔"
    }

  "descriptions": {
    "am": {
      "language": "am",
      "value": "የመሐመድ ባልደረባ"
    },
    "ar": {
      "language": "ar",
      "value": "صحابية عظيمة من السابقين الأولين في الإسلام، وهي ابنة أبي بكر الصديق، وزوجة الزبير بن العوام، وأخت عائشة بنت أبي بكر زوجة النبي محمد"
    },
    "as": {
      "language": "as",
      "value": "মুহাম্মদৰ তৃতীয় পত্নী"
    },
    "az": {
      "language": "az",
      "value": "Əbu Bəkrin qızı, xanım səhabə"
    },
    "ba": {
      "language": "ba",
      "value": "ислам пәйғәмбәре Мөхәммәттең көрәштәше, тәүге хәлифә Әбү Бәкер ас-Ситдыҡтың ҡыҙы"
    },
    "bn": {
      "language": "bn",
      "value": "মোহাম্মদের সাহাবি"
    },
    "ca": {
      "language": "ca",
      "value": "sahabiyya (companya del profeta Muhàmmad) muhàdditha (transmissora i/o estudiós dels hadits)"
    },
    "ckb": {
      "language": "ckb",
      "value": "زاتونیتاقەین"
    },
    "de": {
      "language": "de",
      "value": "Tochter des ersten Kalifen Abū Bakr as-Siddīq ibn Abī Quhāfa"
    },
    "en": {
      "language": "en",
      "value": "One of the first Muslims, and she is the daughter of Abu Bakr Al-Siddiq, the first caliph of the Muslims, the wife of Al-Zubayr bin Al-Awam, the sister of Aisha, the daughter of Abi Bakr, the wife of the Prophet Muha"
    },
    "fr": {
      "language": "fr",
      "value": "Elle est Un des premiers musulmans et la fille du premier calife des musulmans, Abu Bakr Al-Siddiq, l'épouse d'Al-Zubayr bin Al-Awam et la mère d'Abdullah bin Al-Zubayr, qui a été é califat, elle est aussi la soeur d'AïchaL'épouse du prphèt Mohammed"
    },
    "id": {
      "language": "id",
      "value": "putri Abu Bakar Ash-Shiddiq R.A"
    },
    "nl": {
      "language": "nl",
      "value": "muhaddith uit Rashidun-kalifaat (595-692)"
    },
    "tr": {
      "language": "tr",
      "value": "Ebu Bekir'in kızı"
    },
    "ur": {
      "language": "ur",
      "value": "حضرت ابوبکر صدیق کی بڑی بیٹی، حضرت عائشہ ام المؤمنین کی بڑی بہن، خلیفہ عبداللہ بن زبیر کی والدہ۔"
    }
  },

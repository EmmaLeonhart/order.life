      "language": "sv",
      "value": "shiitisk martyr"
    },
    "tr": {
      "language": "tr",
      "value": "Hüseyin'in Kerbela'da şehid edilen kardeşi (647 – 680)"
    },
    "ur": {
      "language": "ur",
      "value": "علی ابن ابی طالب کے بیٹے"
    }

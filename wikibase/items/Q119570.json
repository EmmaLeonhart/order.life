  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "ابن علي بن أبي طالب من زوجته أم البنين"
    },
    "ca": {
      "language": "ca",
      "value": "fill de l'imam Alí ibn Abí-Tàlib"
    },
    "ckb": {
      "language": "ckb",
      "value": "کوڕی عەلی کوڕی ئەبی تالیب (لە ساڵی ٦٨٠ کۆچی دوایی کردووە)"
    },
    "de": {
      "language": "de",
      "value": "Halbbruder des Husain ibn Ali, schiitischer Märtyrer"
    },
    "en": {
      "language": "en",
      "value": "Son of ʿAlī ibn Abī Ṭālib (647-680)"
    },

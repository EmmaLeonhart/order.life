      "language": "fa",
      "value": "برادر ناتنی حسین بن علی (۲۶–۶۱ ه.ق)"
    },
    "hi": {
      "language": "hi",
      "value": "इमाम अली और फातिमा के पुत्र, चर्चित सिफिन और कर्बला की लड़ाई (647-680)"
    },
    "pnb": {
      "language": "pnb",
      "value": "علمدارِ کربلا و فرزند مرتضیٰ"
    },
    "ru": {
      "language": "ru",
      "value": "один из шахидов Кербелы, сподвижников имама Хусейна, убитых в день Ашура"
    },

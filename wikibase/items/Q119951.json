  "descriptions": {
    "ar": {
      "language": "ar",
      "value": "والد جعفر الصادق وحفيد الحسن والحسين ابنا علي بن أبي طالب والإمام الخامس عند الشيعة"
    },
    "bn": {
      "language": "bn",
      "value": "বারো শিয়া ইমামের মধ্যে পঞ্চম ইমাম"
    },
    "bs": {
      "language": "bs",
      "value": "Peti od dvanaest šiitskih imama"
    },
    "de": {
      "language": "de",
      "value": "fünfter Imam der Imamiten und Zaiditen"
    },
    "el": {
      "language": "el",
      "value": "πέμπτος ιμάμης των Σιιτών"
    },
    "en": {
      "language": "en",
      "value": "Fifth of the Twelve Shia Imams"
    },
    "es": {
      "language": "es",
      "value": "quinto imam de los imamíes"
    },
    "fa": {
      "language": "fa",
      "value": "امام پنجم شیعیان اسماعیلی و دوازدهامامی (۹۵–۱۱۴ ه.ق)"
    },
    "fr": {
      "language": "fr",
      "value": "Cinquième imam du chiisme duodécimain"
    },
    "pl": {
      "language": "pl",
      "value": "piąty imam imamitów i ismailitów"
    },
    "ru": {
      "language": "ru",
      "value": "сын имама Зейн аль-Абидина и пятый имам шиитов"
    },
    "sd": {
      "language": "sd",
      "value": "ٻارهن شيعہ امامن مان پنجون امام"
    },
    "ur": {
      "language": "ur",
      "value": "فقیہِ مدینہ اور امامیہ و اسماعیلیہ کے نزدیک پانچویں امام"
    }
  },

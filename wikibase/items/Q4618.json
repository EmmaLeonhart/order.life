  "descriptions": {
    "en": {
      "language": "en",
      "value": "Daughter of Elnathan ben Achbor, Queen of Judah, Wife of Jehoiakim and mother of Jeconiah"
    },
    "he": {
      "language": "he",
      "value": "דמות מקראית, בת אלנתן, אשתו של יהויקים מלך יהודה ואמו של יכניה מלך יהודה"
    },
    "id": {
      "language": "id",
      "value": "Putri Elnathan bin Akhbor, Istri Yoyakim, Ibu Yekhonya, Ratu Yehuda"
    },
    "pt": {
      "language": "pt",
      "value": "Ex-rainha de Judá"
    },
